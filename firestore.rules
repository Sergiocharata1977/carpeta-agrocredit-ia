rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() && role in request.auth.token.get('roles', []);
    }

    function defaultOrgId() {
      return request.auth.token.defaultOrganizationId;
    }

    function isAdminPlatform() {
      return hasRole('admin_platform');
    }

    function isProducer() {
      return hasRole('producer');
    }

    function isAccountant() {
      return hasRole('accountant') || hasRole('accounting_firm_admin');
    }

    function isFinancialEntity() {
      return hasRole('bank_user') || hasRole('agro_company_user');
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function producerOrgId(producerId) {
      return get(/databases/$(database)/documents/producers/$(producerId)).data.organizationId;
    }

    function canReadProducerData(producerId) {
      return isAuthenticated() && (
        isAdminPlatform() ||
        isAccountant() ||
        (isProducer() && producerOrgId(producerId) == defaultOrgId())
      );
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdminPlatform();
      allow update: if isOwner(uid)
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles', 'status']);
      allow create, delete: if false;
    }

    match /organizations/{orgId} {
      allow read: if isAuthenticated();
      allow write: if isAdminPlatform();
    }

    match /organization_members/{memberId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdminPlatform());
      allow write: if isAdminPlatform();
    }

    match /producers/{producerId} {
      allow read: if isAuthenticated() && (
        isAccountant() ||
        isAdminPlatform() ||
        (isProducer() && resource.data.organizationId == defaultOrgId())
      );
      allow create, update: if isAccountant() || isAdminPlatform();
      allow delete: if isAdminPlatform();
    }

    match /accounting_firms/{firmId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant() || isAdminPlatform();
    }

    match /producer_accountant_links/{linkId} {
      allow read: if isAuthenticated() && (isAccountant() || isProducer() || isAdminPlatform());
      allow create, update: if isAdminPlatform() || isAccountant();
      allow delete: if isAdminPlatform();
    }

    match /financial_entities/{entityId} {
      allow read: if isAuthenticated();
      allow write: if isAdminPlatform();
    }

    match /agro_companies/{companyId} {
      allow read: if isAuthenticated();
      allow write: if isAdminPlatform();
    }

    match /accounting_periods/{periodId} {
      allow read: if canReadProducerData(resource.data.producerId);
      allow create, update: if isAccountant() || isAdminPlatform();
      allow delete: if isAdminPlatform();
    }

    match /balance_sheets/{docId} {
      allow read: if canReadProducerData(resource.data.producerId);
      allow create, update: if isAccountant() || isAdminPlatform();
      allow delete: if isAdminPlatform();
    }

    match /income_statements/{docId} {
      allow read: if canReadProducerData(resource.data.producerId);
      allow create, update: if isAccountant() || isAdminPlatform();
      allow delete: if isAdminPlatform();
    }

    match /tax_documents/{docId} {
      allow read: if canReadProducerData(resource.data.producerId);
      allow create, update: if isAccountant() || isAdminPlatform();
      allow delete: if isAdminPlatform();
    }

    match /assets/{docId} {
      allow read: if canReadProducerData(resource.data.producerId);
      allow create, update: if isAccountant() || isAdminPlatform();
      allow delete: if isAdminPlatform();
    }

    match /liabilities/{docId} {
      allow read: if canReadProducerData(resource.data.producerId);
      allow create, update: if isAccountant() || isAdminPlatform();
      allow delete: if isAdminPlatform();
    }

    match /documents/{docId} {
      allow read: if canReadProducerData(resource.data.producerId);
      allow create, update: if isAccountant() || isAdminPlatform();
      allow delete: if isAdminPlatform();
    }

    match /access_requests/{requestId} {
      allow read: if isAuthenticated() && (
        isAdminPlatform() ||
        resource.data.requesterOrganizationId == defaultOrgId() ||
        producerOrgId(resource.data.producerId) == defaultOrgId()
      );
      allow create: if isFinancialEntity()
                    && request.resource.data.requesterOrganizationId == defaultOrgId();
      allow update: if isAdminPlatform()
                    || (isProducer() && producerOrgId(resource.data.producerId) == defaultOrgId());
      allow delete: if false;
    }

    match /access_grants/{grantId} {
      allow read: if isAuthenticated() && (
        isAdminPlatform() ||
        resource.data.grantedToOrganizationId == defaultOrgId() ||
        producerOrgId(resource.data.producerId) == defaultOrgId()
      );
      allow write: if false;
    }

    match /financing_requests/{requestId} {
      allow read: if isAuthenticated() && (
        isAdminPlatform() ||
        resource.data.requesterOrganizationId == defaultOrgId() ||
        producerOrgId(resource.data.producerId) == defaultOrgId()
      );
      allow create: if isFinancialEntity()
                    && request.resource.data.requesterOrganizationId == defaultOrgId();
      allow update: if isFinancialEntity()
                    && resource.data.requesterOrganizationId == defaultOrgId()
                    && request.resource.data.requesterOrganizationId == resource.data.requesterOrganizationId;
      allow delete: if false;
    }

    match /audit_logs/{logId} {
      allow read: if isAdminPlatform();
      allow write: if false;
    }

    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.recipientUid == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.recipientUid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow create, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
