rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() && role in request.auth.token.get('roles', []);
    }

    // Archivos fuente de importaciones OCR/IA. Se sirven por APIs server-side.
    match /orgs/{orgId}/producers/{producerId}/periods/{periodId}/statement-imports/{fileName} {
      allow read, write: if false;
    }

    // Documentos privados del legajo. Upload y descarga pasan por Admin SDK + URL firmada.
    match /orgs/{orgId}/producers/{producerId}/{allPaths=**} {
      allow read, write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
