# Firebase Client (públicas - prefijo NEXT_PUBLIC_)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (privadas - solo server)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic / Claude (server-side — nunca NEXT_PUBLIC_)
# Requerido para el proveedor OCR/IA de EECC. Sin esta variable usa MockOCRProvider.
ANTHROPIC_API_KEY=
# Modelo a usar. Default: claude-haiku-4-5 (más económico para OCR).
# Opciones: claude-haiku-4-5 | claude-sonnet-4-6 | claude-opus-4-8
CLAUDE_MODEL=claude-haiku-4-5

# Scripts locales
# Requerido para pnpm seed:demo
SEED_DEMO_DATA_CONFIRM=
